// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  phone    String @unique
  password String // Hak akses ditunda, fokus ke autentikasi dasar dulu

  unitLogs      UnitLog[]
  accessoryLogs AccessoryLog[]
  blastMessages BlastMessageHistory[]

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  sendInvoiceHistories SendInvoiceHistory[]
  cashflowLogs         CashflowLog[]

  // access
  isSuperAdmin               Boolean
  // access dashboard
  accessDashboardGeneralRead Boolean @default(false)
  // access unit
  accessUnitRead             Boolean @default(false)
  accessUnitCreate           Boolean @default(false)
  accessUnitUpdate           Boolean @default(false)
  accessUnitDelete           Boolean @default(false)
  accessUnitReport           Boolean @default(false)
  // access accessory
  accessAccessoryRead        Boolean @default(false)
  accessAccessoryCreate      Boolean @default(false)
  accessAccessoryUpdate      Boolean @default(false) // edit/purchase (include editing history)
  accessAccessorySell        Boolean @default(false) // only for selling
  accessAccessoryDelete      Boolean @default(false)
  accessAccessoryReport      Boolean @default(false)
  accessAccessoryHistory     Boolean @default(false)
  // access message
  accessMessageSend          Boolean @default(false)
  accessMessageHistory       Boolean @default(false)
  // access customer
  accessCustomerRead         Boolean @default(false)
  accessCustomerCreate       Boolean @default(false)
  accessCustomerUpdate       Boolean @default(false)
  accessCustomerDelete       Boolean @default(false)
  // access user
  accessUserRead             Boolean @default(false)
  accessUserCreate           Boolean @default(false)
  accessUserUpdate           Boolean @default(false)
  accessUserDelete           Boolean @default(false)
  // note: untuk akses user. super admin tidak dapat dihapus, dan selain super admin tidak bisa reset password orang lain
  // access worker
  accessWorkerRead           Boolean @default(false)
  accessWorkerCreate         Boolean @default(false)
  accessWorkerUpdate         Boolean @default(false)
  accessWorkerDelete         Boolean @default(false)
  accessWorkerReport         Boolean @default(false)
  // access information
  accessInformationRead      Boolean @default(false)
  accessInformationUpdate    Boolean @default(false)
  // access cashflow
  accessCashflowRead         Boolean @default(false)
  accessCashflowCreate       Boolean @default(false)
  accessCashflowUpdate       Boolean @default(false)
  accessCashflowDelete       Boolean @default(false)
  otps                       OTP[]
}

model Unit {
  id     Int      @id @default(autoincrement())
  imei   String?  @unique // Identifikasi fisik (opsional jika nanti ada unit non-simcard)
  name   String
  note   String?  @db.Text()
  images String[]

  status Status @default(AVAILABLE)

  buyAt    DateTime?
  buyPrice Int?

  soldAt    DateTime?
  soldPrice Int?
  dpAmount  Int? // Untuk menampung uang muka saat status BOOKED

  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  unitLogs UnitLog[]

  grossProfit Int
  netProfit   Int

  // worker
  workerId  Int?
  worker    Worker? @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerFee Int?

  // payment type
  paymentType PaymentType?
}

enum PaymentType {
  CASH
  DEBIT
  TRANSFER
}

model UnitLog {
  id   Int     @id @default(autoincrement())
  type LogType

  unitId Int
  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  // Dibuat opsional (?) karena saat CREATE tidak ada Before, saat DELETE tidak ada After
  statusBefore Status?
  statusAfter  Status?

  buyPriceBefore Int?
  buyPriceAfter  Int?

  soldPriceBefore Int?
  soldPriceAfter  Int?

  dpAmountBefore Int?
  dpAmountAfter  Int?

  customerIdBefore Int?
  customerBefore   Customer? @relation("customerBefore", fields: [customerIdBefore], references: [id], onDelete: Cascade)

  customerIdAfter Int?
  customerAfter   Customer? @relation("customerAfter", fields: [customerIdAfter], references: [id], onDelete: Cascade)

  noteBefore String? @db.Text()
  noteAfter  String? @db.Text()

  logActionNote String? // Keterangan kenapa log ini dibuat (cth: "Ubah harga jual", "Customer DP")

  // Who changed it
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum LogType {
  CREATE
  UPDATE
  DELETE
}

enum Status {
  AVAILABLE
  BOOKED
  SOLD
  RETURNED
}

model Customer {
  id    Int     @id @default(autoincrement())
  name  String
  phone String?

  units          Unit[]
  unitLogsBefore UnitLog[] @relation("customerBefore")
  unitLogsAfter  UnitLog[] @relation("customerAfter")

  accessorySales       AccessorySale[]
  blastMessages        BlastMessageHistory[]
  sendInvoiceHistories SendInvoiceHistory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Accessory {
  id Int @id @default(autoincrement())

  name   String
  images String[]

  // Set default ke 0 agar mudah saat pembuatan awal
  recordedStock    Int @default(0)
  recordedBuyPrice Int @default(0)
  sellPrice        Int

  purchases AccessoryPurchase[]
  sales     AccessorySaleItem[]
  logs      AccessoryLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model AccessoryPurchase {
  id Int @id @default(autoincrement())

  // WAJIB: Relasi ke Aksesoris
  accessoryId Int
  accessory   Accessory @relation(fields: [accessoryId], references: [id], onDelete: Cascade)

  quantity        Int
  buyPricePerUnit Int
  buyPriceTotal   Int // Opsional tapi bagus untuk mempercepat query report

  note String? @db.Text()

  accessoryLogs AccessoryLog[] // Relasi balik dari Log

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model AccessorySale {
  id Int @id @default(autoincrement())

  // Total akumulasi dari semua items di bawahnya
  totalPrice  Int
  totalProfit Int

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  feeWorker Int

  workerId Int
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  // Relasi ke banyak item
  items AccessorySaleItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accessoryLogs AccessoryLog[]
}

model AccessorySaleItem {
  id Int @id @default(autoincrement())

  saleId Int
  sale   AccessorySale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  accessoryId Int
  accessory   Accessory @relation(fields: [accessoryId], references: [id], onDelete: Cascade)

  quantity Int

  // Harga yang di-freeze saat transaksi terjadi
  recordedBuyPricePerUnit Int
  sellPricePerUnit        Int
  profitPerUnit           Int

  // Log tetap menempel ke detail item agar tahu barang mana yang berubah
  accessoryLogs AccessoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccessoryLog {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relasi Utama
  accessoryId Int
  accessory   Accessory @relation(fields: [accessoryId], references: [id], onDelete: Cascade)

  type LogType
  kind AccessoryKindLogType

  // TRACEABILITY: Relasi ke tabel transaksi pemantik (Opsional karena tipe COMMON tidak punya ini)
  purchaseId Int?
  purchase   AccessoryPurchase? @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  saleId Int?
  sale   AccessorySale? @relation(fields: [saleId], references: [id], onDelete: Cascade)

  saleItemId Int?
  saleItem   AccessorySaleItem? @relation(fields: [saleItemId], references: [id], onDelete: Cascade)

  // Data Perubahan
  beforeName String?
  afterName  String?

  beforeSellPrice Int?
  afterSellPrice  Int?

  beforeRecordedBuyPrice Int?
  afterRecordedBuyPrice  Int?

  beforeRecordedStock Int?
  afterRecordedStock  Int?

  logNote String? @db.Text()

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

enum AccessoryKindLogType {
  COMMON // Perubahan nama/harga jual secara manual
  PURCHASE // Penambahan stok & recalculate MAC
  SALE // Pengurangan stok
}

// Blast Message History
model BlastMessageHistory {
  id      Int    @id @default(autoincrement())
  content String @db.Text()

  status MessageStatus

  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customers Customer[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// Send Invoice History 
model SendInvoiceHistory {
  id      Int    @id @default(autoincrement())
  content String @db.Text()

  status MessageStatus

  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

enum MessageStatus {
  PENDING
  SUCCESS
  FAILED
}

model Worker {
  id Int @id @default(autoincrement())

  name     String
  phone    String
  isActive Boolean @default(true)
  units    Unit[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  accessorySales AccessorySale[]
}

// expected 1 row, if none return default values each field
model CommonInformation {
  id Int @id @default(autoincrement())

  storeName    String
  storeAddress String
  storePhone   String
  storeLogo    String?

  unitFeePercentage Int @default(30)

  footNoteReceipt String? @db.Text()

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Cashflow {
  id Int @id @default(autoincrement())

  type CashflowType

  amount           Int
  note             String   @db.Text()
  imageAttachments String[]
  transactionDate  DateTime

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  cashflowLogs CashflowLog[]
}

enum CashflowType {
  INCOME
  EXPENSE
}

model CashflowLog {
  id Int @id @default(autoincrement())

  cashflowId Int
  cashflow   Cashflow @relation(fields: [cashflowId], references: [id], onDelete: Cascade)

  logType LogType

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountBefore Int?
  amountAfter  Int?

  noteBefore String? @db.Text()
  noteAfter  String? @db.Text()

  imageAttachmentsBefore String[]
  imageAttachmentsAfter  String[]

  cashflowTypeBefore CashflowType?
  cashflowTypeAfter  CashflowType?

  logActionNote String? @db.Text()

  transactionDateBefore DateTime?
  transactionDateAfter  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model OTP {
  id         Int      @id @default(autoincrement())
  identifier String   @unique // Only Phone
  code       String   @db.VarChar(6)
  expiresAt  DateTime // + 5 menit
  used       Boolean  @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// rules:
// - identifier unique
// - 6 digit code 
// - expires after 5 minutes
// - used true only once
// - user must exist
// - can be resend after 1 minute
// - must send via whatsapp
// - use for reset password 
